# Handle line endings for cross-platform (Windows/WSL/Linux) multi-agent work
* text=auto
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.zip binary
*.tar binary
*.gz binary
prod-grok-backend.json binary
